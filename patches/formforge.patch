diff --git a/FORMFORGE_NOTES.md b/FORMFORGE_NOTES.md
new file mode 100644
index 0000000..6e5b3bd
--- /dev/null
+++ b/FORMFORGE_NOTES.md
@@ -0,0 +1,14 @@
+# FormForge Studio source integration
+
+This Blender 5.3 alpha source tree includes the FormForge Studio Maya-inspired
+workflow layer. The application title is branded in
+`source/blender/windowmanager/intern/wm_window.cc`; the workflow add-on belongs
+under `scripts/addons_core/formforge_maya_ui` in a packaged build.
+
+For a local Windows source build, follow Blender's normal Visual Studio build
+instructions, then copy the FormForge add-on beside the packaged core add-ons.
+The ready-to-test installer uses Blender 5.1.1 stable because the supplied 5.3
+tree is an alpha development snapshot.
+
+All Blender-derived work remains under the GNU GPL. FormForge Studio does not
+include or redistribute Autodesk Maya code or assets.
diff --git a/build_files/windows/find_blender.cmd b/build_files/windows/find_blender.cmd
index 9adbfd3..7d7d9f6 100644
--- a/build_files/windows/find_blender.cmd
+++ b/build_files/windows/find_blender.cmd
@@ -5,19 +5,19 @@ if EXIST "%BLENDER_BIN%" (
 
 REM Check the build folder next, if ninja was used there will be no
 REM debug/release folder
-set BLENDER_BIN=%BUILD_DIR%\bin\blender.exe
+set BLENDER_BIN=%BUILD_DIR%\bin\FormForge.exe
 if EXIST "%BLENDER_BIN%" (
     goto detect_blender_done
 )
 
 REM Check the release folder next
-set BLENDER_BIN=%BUILD_DIR%\bin\release\blender.exe
+set BLENDER_BIN=%BUILD_DIR%\bin\release\FormForge.exe
 if EXIST "%BLENDER_BIN%" (
     goto detect_blender_done
 )
 
 REM Check the debug folder next
-set BLENDER_BIN=%BUILD_DIR%\bin\debug\blender.exe
+set BLENDER_BIN=%BUILD_DIR%\bin\debug\FormForge.exe
 if EXIST "%BLENDER_BIN%" (
     goto detect_blender_done
 )
